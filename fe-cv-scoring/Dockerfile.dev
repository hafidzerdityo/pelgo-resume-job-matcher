FROM node:20-alpine

WORKDIR /app

# Install dependencies first for better caching
COPY package*.json ./
RUN npm install

# Copy the rest of the source code
COPY . .

# Essential for Docker/Windows/WSL2 file watching
ENV WATCHPACK_POLLING=true

EXPOSE 3000

# Run in development mode for hot-reload
CMD ["npm", "run", "dev"]
